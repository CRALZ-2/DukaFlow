// ══════════════════════════════════════════════════════
// DukaFlow — Prisma Schema
// Phase 2: Seed Models | Phase 3: User | Phase 4: Shop + ShopEmployee
// ══════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────

enum PlanName {
  FREE
  PRO
  ENTERPRISE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ShopStatus {
  PENDING
  ACTIVE
  SUSPENDED
  READ_ONLY
}

// ─── Model: Currency ──────────────────────────────────

model Currency {
  id        String    @id @default(uuid()) @db.VarChar(36)
  code      String    @unique @db.VarChar(5)
  name      String    @db.VarChar(100)
  symbol    String    @db.VarChar(10)
  isActive  Boolean   @default(true) @map("is_active")

  // Relations
  shops     Shop[]

  // Hidden / audit fields
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.VarChar(36)
  updatedBy String?   @map("updated_by") @db.VarChar(36)

  @@map("currencies")
}

// ─── Model: Category ─────────────────────────────────

model Category {
  id          String    @id @default(uuid()) @db.VarChar(36)
  name        String    @unique @db.VarChar(100)
  slug        String    @unique @db.VarChar(120)
  description String?   @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")

  // Relations
  shops       Shop[]
  products    Product[]

  // Hidden / audit fields
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.VarChar(36)
  updatedBy   String?   @map("updated_by") @db.VarChar(36)

  @@map("categories")
}

// ─── Model: SubscriptionPlan ─────────────────────────

model SubscriptionPlan {
  id            String    @id @default(uuid()) @db.VarChar(36)
  name          PlanName  @unique
  description   String?   @db.VarChar(255)
  maxProducts   Int       @map("max_products")
  maxEmployees  Int       @map("max_employees")
  priceMonthly  Decimal?  @map("price_monthly") @db.Decimal(15, 2)
  priceYearly   Decimal?  @map("price_yearly") @db.Decimal(15, 2)
  features      Json
  isActive      Boolean   @default(true) @map("is_active")

  // Hidden / audit fields
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  createdBy     String?   @map("created_by") @db.VarChar(36)
  updatedBy     String?   @map("updated_by") @db.VarChar(36)

  @@map("subscription_plans")
}

// ─── Model: User ──────────────────────────────────────

model User {
  // Identity
  id              String    @id @default(uuid()) @db.VarChar(36)
  email           String    @unique @map("email")
  password        String    @map("password_hash")

  // Profile
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  gender          Gender?   @map("gender")

  // Auth flow flags
  isActive        Boolean   @default(true) @map("is_active")
  mustChangePassword Boolean @default(false) @map("must_change_password")
  lastLoginAt     DateTime? @map("last_login_at")
  loginCount      Int       @default(0) @map("login_count")

  // Invite / Reset tokens
  inviteToken     String?   @unique @map("invite_token")
  inviteExpiry    DateTime? @map("invite_expiry")
  passwordResetToken String? @unique @map("password_reset_token")
  passwordResetExpiry DateTime? @map("password_reset_expiry")

  // Relations (Phase 4)
  shopEmployees   ShopEmployee[]

  // Hidden audit fields
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  createdBy       String?   @map("created_by")
  updatedBy       String?   @map("updated_by")

  @@map("users")
  @@index([email])
  @@index([inviteToken])
  @@index([passwordResetToken])
}

// ─── Model: Shop ──────────────────────────────────────

model Shop {
  // Identity
  id                     String      @id @default(uuid()) @db.VarChar(36)
  name                   String      @db.VarChar(150)
  slug                   String      @unique @db.VarChar(180)
  logoUrl                String?     @map("logo_url") @db.VarChar(500)

  // Business info
  categoryId             String      @map("category_id") @db.VarChar(36)
  category               Category    @relation(fields: [categoryId], references: [id])

  // Contact & location
  whatsapp               String      @db.VarChar(20)
  country                String      @db.VarChar(100)
  region                 String?     @db.VarChar(100)
  city                   String      @db.VarChar(100)

  // Currency
  currencyId             String      @map("currency_id") @db.VarChar(36)
  currency               Currency    @relation(fields: [currencyId], references: [id])

  // Subscription & status
  subscriptionPlan       PlanName    @default(FREE) @map("subscription_plan")
  subscriptionStartDate  DateTime?   @map("subscription_start_date")
  subscriptionExpiryDate DateTime?   @map("subscription_expiry_date")
  isTrialPeriod          Boolean     @default(true) @map("is_trial_period")
  trialEndsAt            DateTime?   @map("trial_ends_at")
  status                 ShopStatus  @default(PENDING) @map("status")

  // Referral & counters
  referralCode           String?     @unique @map("referral_code") @db.VarChar(10)
  saleCounter            Int         @default(0) @map("sale_counter")

  // Relations
  shopEmployees          ShopEmployee[]
  products               Product[]

  // Hidden audit fields
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")
  deletedAt              DateTime?   @map("deleted_at")
  createdBy              String?     @map("created_by") @db.VarChar(36)
  updatedBy              String?     @map("updated_by") @db.VarChar(36)

  @@map("shops")
  @@index([slug])
  @@index([whatsapp])
  @@index([status])
  @@index([categoryId])
  @@index([currencyId])
}

// ─── Model: ShopEmployee (Pivot: User ↔ Shop) ────────

model ShopEmployee {
  id        String    @id @default(uuid()) @db.VarChar(36)
  userId    String    @map("user_id") @db.VarChar(36)
  shopId    String    @map("shop_id") @db.VarChar(36)
  role      String    @db.VarChar(20) // OWNER, MANAGER, CASHIER
  isActive  Boolean   @default(true) @map("is_active")

  // Relations
  user      User      @relation(fields: [userId], references: [id])
  shop      Shop      @relation(fields: [shopId], references: [id])

  // Hidden audit fields
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.VarChar(36)
  updatedBy String?   @map("updated_by") @db.VarChar(36)

  @@unique([userId, shopId]) // One role per user per shop
  @@map("shop_employees")
  @@index([userId])
  @@index([shopId])
}

// ─── Phase 7: Products + Stock ────────────────────────

enum StockMovementType {
  ADDITION    // Manual stock add
  REMOVAL     // Manual stock remove
  SALE        // Deducted via sale
  REVERSAL    // Sale reversed/refunded
  ADJUSTMENT  // Inventory correction
}

// ─── Model: Product ───────────────────────────────────

model Product {
  id                 String    @id @default(uuid()) @db.VarChar(36)
  shopId             String    @map("shop_id") @db.VarChar(36)
  shop               Shop      @relation(fields: [shopId], references: [id])

  // Classification
  categoryId         String    @map("category_id") @db.VarChar(36)
  category           Category  @relation(fields: [categoryId], references: [id])
  subcategory        String?   @db.VarChar(100)

  // Identity
  name               String    @db.VarChar(200)
  sku                String    @map("sku") @db.VarChar(50)
  barcode            String?   @db.VarChar(100)
  description        String?   @db.Text
  unit               String    @default("pcs") @db.VarChar(20) // pcs, kg, L, m, etc.

  // Pricing
  purchasePrice      Decimal   @map("purchase_price") @db.Decimal(15, 2)
  salePrice          Decimal   @map("sale_price") @db.Decimal(15, 2)
  taxRate            Decimal   @default(0) @map("tax_rate") @db.Decimal(5, 2)

  // Promotion
  isPromotion        Boolean   @default(false) @map("is_promotion")
  promoPrice         Decimal?  @map("promo_price") @db.Decimal(15, 2)
  promoStartAt       DateTime? @map("promo_start_at")
  promoEndAt         DateTime? @map("promo_end_at")

  // Stock
  currentStock       Int       @default(0) @map("current_stock")
  lowStockThreshold  Int       @default(5) @map("low_stock_threshold")

  // Status
  isActive           Boolean   @default(true) @map("is_active")

  // Relations
  images             ProductImage[]
  stockMovements     StockMovement[]

  // Hidden audit fields
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")
  createdBy          String?   @map("created_by") @db.VarChar(36)
  updatedBy          String?   @map("updated_by") @db.VarChar(36)

  @@unique([shopId, sku])
  @@map("products")
  @@index([shopId])
  @@index([categoryId])
  @@index([sku])
  @@index([barcode])
  @@index([isActive])
}

// ─── Model: ProductImage ──────────────────────────────

model ProductImage {
  id        String   @id @default(uuid()) @db.VarChar(36)
  productId String   @map("product_id") @db.VarChar(36)
  product   Product  @relation(fields: [productId], references: [id])
  url       String   @db.VarChar(500)
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by") @db.VarChar(36)
  updatedBy String?  @map("updated_by") @db.VarChar(36)

  @@map("product_images")
  @@index([productId])
}

// ─── Model: StockMovement ────────────────────────────

model StockMovement {
  id            String             @id @default(uuid()) @db.VarChar(36)
  productId     String             @map("product_id") @db.VarChar(36)
  product       Product            @relation(fields: [productId], references: [id])
  shopId        String             @map("shop_id") @db.VarChar(36)

  type          StockMovementType  @map("type")
  quantity      Int                // positive=add, negative=remove
  previousStock Int                @map("previous_stock")
  newStock      Int                @map("new_stock")

  location      String?            @db.VarChar(100)
  notes         String?            @db.VarChar(500)
  referenceId   String?            @map("reference_id") @db.VarChar(36) // FK to sale/batch

  // Hidden audit fields
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  deletedAt     DateTime?          @map("deleted_at")
  createdBy     String?            @map("created_by") @db.VarChar(36)
  updatedBy     String?            @map("updated_by") @db.VarChar(36)

  @@map("stock_movements")
  @@index([productId])
  @@index([shopId])
  @@index([type])
  @@index([referenceId])
}
