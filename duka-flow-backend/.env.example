# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────
DATABASE_URL="mysql://root:@localhost:3306/dukaflow_db"

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_REFRESH_EXPIRES_IN=7d

# ─── Uploads ──────────────────────────────────────────
UPLOAD_PATH=uploads
